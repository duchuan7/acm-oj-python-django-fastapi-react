DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://example.com,http://www.example.com
CORS_ALLOWED_ORIGINS=http://example.com,http://www.example.com

POSTGRES_DB=acmoj
POSTGRES_USER=acmoj
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
BACKEND_BASE_URL=http://backend:8000

JUDGE_INTERNAL_TOKEN=replace-with-long-random-judge-token
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=replace-with-strong-admin-password
DEMO_ADMIN_EMAIL=admin@example.com

SUBMISSION_CODE_MAX_BYTES=65536
SUBMISSION_RATE_LIMIT_SECONDS=1
JUDGE_WORKDIR=/tmp/acmoj-run
JUDGE_DOCKER_NETWORK=none
JUDGE_RUNS_VOLUME=acmoj_prod_judge_runs
TESTCASE_VOLUME=acmoj_prod_testcase_data
