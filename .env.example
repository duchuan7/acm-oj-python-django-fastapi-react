DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

POSTGRES_DB=acmoj
POSTGRES_USER=acmoj
POSTGRES_PASSWORD=acmoj_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
BACKEND_BASE_URL=http://backend:8000
JUDGE_INTERNAL_TOKEN=change-me-judge-token
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=change-me-local-admin-password
DEMO_ADMIN_EMAIL=admin@example.com

SUBMISSION_CODE_MAX_BYTES=65536
SUBMISSION_RATE_LIMIT_SECONDS=1
JUDGE_WORKDIR=/tmp/acmoj-run
JUDGE_DOCKER_NETWORK=none
JUDGE_RUNS_VOLUME=acmoj_judge_runs
TESTCASE_VOLUME=acmoj_testcase_data
